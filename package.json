    "gray-matter": "^4.0.3",
    "jsonschema": "^1.5.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^4.0.0",
    "sass": "^1.99.0"
  },
  "dependencies": {
    "practice-js": "github:gurukulams/practice-js"
  }
}
